{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "clickup": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@taazkareem/clickup-mcp-server@0.8.4",
        "--hash",
        "sha512:TuWPCubHFrRNbghj34th+QFdOqwGljs0QP55s+d73JhsFVoKaXFuS4c5bHat8qwV9UyF6hAeX87UP0SmeH/QRg=="
      ],
      "environment": {
        "CLICKUP_API_KEY": "REPLACE_WITH_YOUR_KEY",
        "CLICKUP_TEAM_ID": "arq",
        "DOCUMENT_SUPPORT": "{{DOCUMENT_SUPPORT}}"
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}"
      }
    },
    "codegen": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/codegen-sh/codegen-sdk.git#egg=codegen-mcp-server&subdirectory=codegen-examples/examples/codegen-mcp-server",
        "codegen-mcp-server"
      ]
    },
    "figma-dev-mode": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/sse"
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\wilso"
      ]
    },
    "genkit": {
      "type": "local",
      "command": [
        "npm",
        "install",
        "@genkit-ai/mcp"
      ]
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_YOUR_TOKEN"
      }
    },
    "supabase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@0.5.5",
        "--access-token",
        "sbp_REPLACE_WITH_YOUR_TOKEN"
      ]
    }
  }
}
